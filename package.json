{
  "name": "that-gpt",
  "version": "2.6.2",
  "description": "ThatGPT — local ChatGPT-style desktop chat for OpenAI-compatible APIs and Ollama",
  "license": "MIT",
  "private": false,
  "scripts": {
    "dev": "tauri dev",
    "tauri": "tauri",
    "build": "tauri build && node scripts/stage-portable.mjs",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build && node scripts/stage-portable.mjs",
    "build:installer": "tauri build --bundles nsis && node scripts/stage-portable.mjs",
    "build:portable": "tauri build --bundles none && node scripts/stage-portable.mjs",
    "dev:client": "npm --prefix client run dev",
    "build:client": "npm --prefix client run build",
    "generate:brand": "node scripts/generate-brand-assets.mjs",
    "test:rust": "cargo test --manifest-path src-tauri/Cargo.toml",
    "android:init": "node scripts/mobile-android-init.mjs",
    "android:dev": "tauri android dev",
    "android:build:apk:debug": "npm run android:init && tauri android build --ci --apk --debug",
    "android:build:apk:unsigned": "npm run android:init && tauri android build --ci --apk",
    "android:build": "npm run android:build:apk:debug",
    "ios:init": "tauri ios init --ci",
    "ios:build:sim": "npm run ios:init && tauri ios build --ci --target aarch64-sim",
    "ios:build:sim:intel": "npm run ios:init && tauri ios build --ci --target x86_64-sim",
    "mobile:collect": "node scripts/collect-mobile-artifacts.mjs",
    "release:package": "powershell -ExecutionPolicy Bypass -File scripts/package-release.ps1",
    "release:hashes": "powershell -ExecutionPolicy Bypass -File scripts/generate-sha256.ps1",
    "release:verify": "powershell -ExecutionPolicy Bypass -File scripts/generate-sha256.ps1 -Package",
    "clean": "powershell -ExecutionPolicy Bypass -File scripts/clean-project.ps1",
    "clean:all": "powershell -ExecutionPolicy Bypass -File scripts/clean-project.ps1 -All -Release",
    "postinstall": "npm install --prefix client"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.2"
  }
}
