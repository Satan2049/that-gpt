{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ChatNest",
  "version": "2.0.0",
  "identifier": "com.chatnest.desktop",
  "build": {
    "frontendDist": "../client/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev --prefix client",
    "beforeBuildCommand": "npm run build --prefix client"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "ChatNest",
        "width": 1200,
        "height": 800,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "category": "Productivity",
    "copyright": "Copyright © 2026 ChatNest contributors",
    "shortDescription": "Desktop chat for OpenAI-compatible APIs",
    "longDescription": "ChatNest is a local-first desktop chat client with prompt presets, vision support, and JSON file storage.",
    "homepage": "https://github.com/chatnest/chat-nest",
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper",
        "silent": true
      },
      "nsis": {
        "installMode": "currentUser",
        "installerIcon": "icons/icon.ico",
        "displayLanguageSelector": false,
        "languages": ["English"],
        "compression": "lzma"
      }
    }
  }
}
