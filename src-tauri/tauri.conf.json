{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ThatGPT",
  "version": "2.6.2",
  "identifier": "com.thatgpt.desktop",
  "build": {
    "frontendDist": "../client/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev --prefix client",
    "beforeBuildCommand": "npm run build --prefix client"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "ThatGPT",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "category": "Productivity",
    "copyright": "Copyright © 2026 ThatGPT contributors",
    "shortDescription": "Local ChatGPT-style desktop chat",
    "longDescription": "ThatGPT is a local-first desktop chat client for OpenAI-compatible APIs and Ollama, with prompt presets, vision support, and JSON file storage.",
    "homepage": "https://github.com/Satan2049/that-gpt",
    "targets": ["nsis", "dmg", "appimage"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper",
        "silent": true
      },
      "nsis": {
        "installMode": "currentUser",
        "installerIcon": "icons/icon.ico",
        "displayLanguageSelector": false,
        "languages": ["English"],
        "compression": "lzma"
      }
    }
  }
}
