# Place AI provider credentials in the ChatNest app data directory as `.env`.
# Windows: %APPDATA%\com.chatnest.desktop\.env
# macOS: ~/Library/Application Support/com.chatnest.desktop/.env
# Linux: ~/.local/share/com.chatnest.desktop/.env

AI_API_KEY=
AI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4o-mini
AI_IMAGE_MODEL=
AI_AUDIO_MODEL=
AI_DEFAULT_SYSTEM_PROMPT=You are a helpful assistant.
AI_REQUEST_TIMEOUT_MS=60000
AI_MAX_RETRIES=2
